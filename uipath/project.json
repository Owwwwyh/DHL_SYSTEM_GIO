  "main": "Main.xaml",
  "dependencies": {
    "UiPath.System.Activities": "[24.10.4]",
    "UiPath.WebAPI.Activities": "[1.21.0]",
    "UiPath.Mail.Activities": "[1.23.4]",
    "UiPath.GSuite.Activities": "[1.16.4]"
  },
  "schemaVersion": "4.0",
  "studioVersion": "24.10.0.0",
  "projectVersion": "1.0.0",
  "runtimeOptions": {
    "autoDispose": false,
    "isAttended": false,
    "requiresUserInteraction": false,
    "supportsPersistence": false,
    "excludedLoggedData": ["Private:*", "*Password*"]
  },
  "designOptions": {
    "projectProfile": "Development",
    "outputType": "Process"
  },
  "expressionLanguage": "VisualBasic"
}

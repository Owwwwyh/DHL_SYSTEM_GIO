# Database (PostgreSQL)
# Local Docker: docker run --name dhl-pg -e POSTGRES_PASSWORD=postgres -e POSTGRES_DB=dhl_kb -p 5432:5432 -d postgres:16
# Hosted options: Neon, Supabase, Railway, Render
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/dhl_kb?schema=public"

# NextAuth
NEXTAUTH_SECRET="generate-a-random-string-here"
NEXTAUTH_URL="http://localhost:3000"

# Google Gemini API (free at aistudio.google.com)
GEMINI_API_KEY="your-gemini-api-key-here"

# UiPath API Key (any string you choose - used to authenticate UiPath calls)
UIPATH_API_KEY="dhl-uipath-secret-2024"

# Seed passwords (optional). Leave unset to have `npm run seed` generate
# random passwords and print them once. Min 8 chars when set.
# SEED_ADMIN_PASSWORD=
# SEED_EDITOR_PASSWORD=
